# ==================== PLANTILLA DE CONFIGURACIÓN T+PLUS ====================
# Copia este archivo como .env y completa con tus valores reales

# 🗃️ SUPABASE (Obligatorio)
SUPABASE_URL=https://tu-proyecto-id.supabase.co
SUPABASE_ANON_KEY=tu_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui
SUPABASE_JWT_SECRET=tu_jwt_secret_aqui

# 📱 APP T+PLUS (Obligatorio)
APP_NAME=T+Plus
APP_DISPLAY_NAME=TmasPlus
APP_VERSION=1.10.3
APP_IDENTIFIER=com.treasapp.tmasplus
APP_IDENTIFIER_IOS=tmasplus.tmasplus

# 🗺️ GOOGLE MAPS (Obligatorio)
GOOGLE_MAPS_API_KEY_IOS=tu_api_key_ios
GOOGLE_MAPS_API_KEY_ANDROID=tu_api_key_android

# 📊 SENTRY (Opcional pero recomendado)
SENTRY_DSN=tu_sentry_dsn
SENTRY_ENVIRONMENT=development

# 🚀 EXPO (Obligatorio)
EXPO_PROJECT_ID=tu_expo_project_id
EXPO_OWNER=tu_expo_owner
EXPO_SLUG=tu_expo_slug

# 🌐 FUNCTIONS
FIREBASE_FUNCTIONS_URL=https://us-central1-tu-proyecto.cloudfunctions.net

# 🏭 ENTORNO
NODE_ENV=development
APP_ENV=development
